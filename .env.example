# Turso Database Configuration
# ตั้งค่าฐานข้อมูล Turso (SQLite Cloud)

# URL ของฐานข้อมูล Turso
# ได้จาก: https://turso.tech/
TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io

# Authentication Token สำหรับเชื่อมต่อ
# ได้จาก: Turso Dashboard > Database > Tokens
TURSO_AUTH_TOKEN=your-auth-token-here
