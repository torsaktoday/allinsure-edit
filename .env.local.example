# ===== DATABASE CONFIGURATION =====
# ฐานข้อมูล Turso (SQLite Cloud)
# ได้จาก: https://turso.tech/

# Database URL
# ตัวอย่าง: libsql://my-database-myorg.turso.io
TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io

# Authentication Token
# ได้จาก Turso Dashboard > Database > Tokens
TURSO_AUTH_TOKEN=your-auth-token-here

# ===== OPTIONAL: LOCAL DATABASE =====
# ถ้าไม่ตั้ง TURSO_DATABASE_URL จะใช้ local file: safeguard.db
# TURSO_DATABASE_URL=file:safeguard.db
